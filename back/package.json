  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "nodemon ./src/index.ts --watch ./src",
    "start:prod": "node ./build/index.js",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint --fix src/",
    "prettier": "npx prettier src --check",
    "prettier:fix": "npm run prettier -- --write",
    "migrate": "npx prisma migrate dev --name init",
    "format": "npm run prettier:fix src/ && npm run lint:fix src/",
    "build": "npx tsc",
    "swagger": "ts-node src/swagger.ts"
  },
  "dependencies": {
    "@prisma/client": "6.12.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "envalid": "^8.0.0",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "multer": "^1.4.5-lts.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.19.15",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.15.0",
    "install": "^0.13.0",
    "nodemon": "^3.1.7",
    "prettier": "3.3.3",
    "prisma": "6.12.0",
    "swagger-autogen": "^2.23.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2"
  },
  "prisma": {
    "seed": "ts-node ./prisma/seed.ts"
  },
  "allowScripts": {
    "@prisma/client@6.12.0": true,
    "@prisma/engines@6.12.0": true,
